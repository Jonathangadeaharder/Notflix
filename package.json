{
  "name": "notflix-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.0",
  "devDependencies": {
    "drizzle-orm": "0.45.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "pnpm -r --if-present run lint",
    "check": "pnpm -r --if-present run check"
  },
  "lint-staged": {
    "apps/platform/**/*.{ts,svelte}": [
      "eslint --config apps/platform/eslint.config.js --fix",
      "prettier --write"
    ],
    "apps/ai-service/**/*.py": [
      "uvx --from ruff ruff check --fix",
      "uvx --from ruff ruff format"
    ],
    "packages/database/**/*.ts": [
      "eslint --config packages/database/eslint.config.js --fix",
      "prettier --write"
    ],
    "packages/shared-types/**/*.ts": [
      "eslint --config packages/shared-types/eslint.config.js --fix",
      "prettier --write"
    ]
  }
}
