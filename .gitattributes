# Normalize line endings to LF in the repository, check out as LF everywhere.
# This prevents lint-staged stash conflicts on Windows (CRLF/LF mismatch).
* text=auto eol=lf

# Binary files — never touch line endings
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.mp4 binary
*.mp3 binary
*.vtt text eol=lf
*.bat text eol=crlf
