# ── Version control ──────────────────────────────────────
.git

# ── Dependencies (host-specific, never belong in images) ─
**/node_modules
**/.pnpm-store
**/venv
**/.venv
**/__pycache__

# ── Build artifacts ──────────────────────────────────────
apps/platform/.svelte-kit
.pytest_cache
.ruff_cache

# ── Test artifacts ───────────────────────────────────────
test-results
playwright-report

# ── Editor / IDE ─────────────────────────────────────────
.vscode
.idea

# ── Runtime data (bind-mounted separately) ───────────────
media
logs
*.log
