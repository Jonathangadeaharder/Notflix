# Database (Supabase Postgres)
DATABASE_URL=postgres://postgres:<POSTGRES_PASSWORD>@127.0.0.1:5432/postgres

# AI Service Connection
AI_SERVICE_URL=http://127.0.0.1:8000
AI_SERVICE_API_KEY=dev_secret_key

# Supabase — server-side only (not exposed to browser)
# For local dev this is the same as PUBLIC_SUPABASE_URL; in Docker it points to kong:8000 via compose env
SUPABASE_URL=http://localhost:8000

# Supabase — public (must be reachable from the user's browser)
PUBLIC_SUPABASE_URL=http://localhost:8000
PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Optional: Override upload directory
# UPLOAD_DIR=media/uploads
