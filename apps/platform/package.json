{
  "name": "@notflix/platform",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "gen:brain-types": "pnpm exec openapi-typescript ../../apps/ai-service/openapi.json -o src/lib/server/infrastructure/brain-api.d.ts --export-type",
    "lint": "eslint .",
    "lint:dup": "jscpd src",
    "lint:md": "markdownlint **/*.md",
    "lint:arch": "depcruise src --config .dependency-cruiser.cjs",
    "lint:all": "pnpm run check && pnpm run lint && pnpm run lint:dup && pnpm run lint:md && pnpm run lint:arch",
    "lint:contract": "pnpm exec spectral lint ../../apps/ai-service/openapi.json --ruleset ../../.spectral.yaml",
    "lint:secrets": "secretlint \"**/*\"",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:server": "vite build && vite preview --port 5173",
    "test:e2e:docker": "cd ../../ && docker compose -f docker-compose.yml -f docker-compose.test.yml up -d --wait && cd apps/platform && pnpm run test:e2e; cd ../../ && docker compose down",
    "story:dev": "histoire dev",
    "story:build": "histoire build"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@histoire/plugin-svelte": "^0.17.17",
    "@playwright/test": "^1.59.1",
    "@stoplight/spectral-cli": "^6.15.0",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.56.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@testcontainers/postgresql": "^11.13.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/eslint-plugin": "^1.6.14",
    "autoprefixer": "^10.4.27",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.2.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-svelte": "^3.17.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "globals": "^17.4.0",
    "histoire": "^0.17.17",
    "jscpd": "^4.0.8",
    "jsdom": "^29.0.1",
    "lucide-svelte": "^1.0.1",
    "markdownlint-cli": "^0.48.0",
    "openapi-typescript": "^7.13.0",
    "postcss": "^8.5.8",
    "secretlint": "^11.4.1",
    "svelte": "^5.55.1",
    "svelte-check": "^4.4.6",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@notflix/database": "file:../../packages/database",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "pino": "^10.3.0",
    "postgres": "^3.4.8",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  }
}
