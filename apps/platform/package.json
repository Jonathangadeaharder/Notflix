{
  "name": "@notflix/platform",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "gen:brain-types": "pnpm exec openapi-typescript ../../apps/ai-service/openapi.json -o src/lib/server/infrastructure/brain-api.d.ts --export-type",
    "lint": "biome check .",
    "lint:all": "pnpm run check && pnpm run lint",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/lib/server/db/seed.ts",
    "test:unit": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:server": "vite build && node build",
    "test:e2e:docker": "cd ../../ && docker compose down -v && docker compose -f docker-compose.yml -f docker-compose.test.yml up -d --wait && cd apps/platform && pnpm run test:e2e",
    "test:e2e:docker:clean": "cd ../../ && docker compose down -v"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@vitest/coverage-v8": "^4.0.18",
    "autoprefixer": "^10.4.22",
    "drizzle-kit": "^0.31.0",
    "jsdom": "^29.0.1",
    "lucide-svelte": "^0.563.0",
    "openapi-typescript": "^7.10.1",
    "postcss": "^8.5.10",
    "svelte": "^5.49.1",
    "svelte-check": "^4.3.4",
    "tailwindcss": "^4.1.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.8",
    "clsx": "^2.1.1",
    "drizzle-orm": "0.45.2",
    "pino": "^10.3.0",
    "postgres": "^3.4.8",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.4"
  }
}
